# EduCenter OS Environment Example

APP_NAME=EduCenter OS
APP_ENV=development

# Backend
BACKEND_PORT=8000

# Frontend
FRONTEND_PORT=3000

# Database
POSTGRES_DB=educenter
POSTGRES_USER=educenter_user
POSTGRES_PASSWORD=educenter_password
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# Security
JWT_SECRET_KEY=change_this_secret_key
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440